  "keyFeatures": [
    "Dual module system for printers and computers",
    "Real-time report status tracking with workflow management",
    "Automated email notifications to stakeholders",
    "ORBE ticket system integration with HTML parsing",
    "Equipment database with autocomplete",
    "Excel report generation",
    "MongoDB-based data persistence",
    "FastAPI REST API backend"
  ],
  "publicApiSurface": [
    "POST /api/reports - Create printer failure report",
    "POST /api/reports-computadoras - Create computer failure report",
    "GET /api/reports - List all reports",
    "PATCH /api/reports/{id}/estado - Update report status",
    "POST /api/parse-boleta - Parse ORBE HTML boleta",
    "GET /api/autocomplete/activos - Autocomplete asset codes",
    "GET /api/autocomplete/informaticos - Autocomplete technician names",
    "POST /api/smtp/configure - Configure SMTP settings",
    "GET /api/impresoras - List printers",
